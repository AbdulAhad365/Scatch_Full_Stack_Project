<%- include('./partials/header') %>


    <div class="main-class  ">

        <%user.card.forEach((item)=>{%>

        <%var discount=Math.floor(item.product.discount*(item.quantity*item.product.price)/100)%>
        <%var net_price=item.quantity*item.product.price%>
        <%var final_price=net_price-discount+20%>

      

        <div class="w-full  flex items-start px-20 py-10 gap-10">
            <!-- left side -->
            
            <div class="w-[30%] rounded-md overflow-hidden">
                <!-- <div class="w-full h-80 bg-yellow-500"> -->
                    <div class="w-full h-52 flex items-center justify-center bg-[<%= item.product.bgColor %>]">
                            <img class="h-[12rem]" src="data:<%= item.product.imageType %>;base64,<%= item.product.image.toString('base64') %>" alt=""`>
                        </div>
                <!-- </div> -->
                <div class="w-full flex justify-between px-5 py-4">
                    <h3 class="text-2xl">Clinge Bag</h3>
                    <div class="flex items-center gap-2">
                        <i class="w-7 h-7 bg-white flex rounded-full items-center justify-center ri-add-line"></i>
                        <div class="px-2 py-1 rounded-md bg-white text-black"><%=item.quantity%></div>
                        <i class="w-7 h-7 bg-white flex rounded-full items-center justify-center ri-subtract-line"></i>
                    </div>
                </div>
                <div class="flex items-center justify-between px-5 py-3">
                    <h4 class="text-lg">Net Total</h4>
                    <h2 class="text-lg">₹ <%=net_price%></h2>
                </div>
            </div>


            <!-- right sidde -->
            <div class="w-[70%]">
                <h3 class="text-xl">Price Breakdown</h3>
                <div class="px-10 mt-5">
                    <div class="flex mt-2">
                        <h4 class="w-1/3">Total MRP</h4>
                        <h4>₹ <%=item.quantity*item.product.price%></h4>
                    </div>
                    <div class="flex mt-2">
                        <h4 class="w-1/3">Discount on MRP</h4>
                        <h4>₹  <%=discount%> </h4>
                    </div>
                    <div class="flex mt-2">
                        <h4 class="w-1/3">Platform Fee</h4>
                        <h4>₹ 20</h4>
                    </div>
                    <div class="flex mt-2">
                        <h4 class="w-1/3">Shipping Fee</h4>
                        <h4>FREE</h4>
                    </div>
                </div>
                <div class="w-full h-[1px] bg-black mt-10"></div>
                <div class="flex mt-5">
                    <h3 class="w-1/3 text-xl">Total Amount</h3>
                    <h3 class="font-semibold text-xl text-green-600">₹ <%=final_price%></h3>
                </div>
                <form action=""></form>
            </div>
        </div>
    <%})%>

</div>

    <%- include('./partials/footer') %>